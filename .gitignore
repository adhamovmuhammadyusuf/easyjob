# .gitignore for a Node.js project and Django application
# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# build output
build/
dist/

# 
package-lock.json
yarn.lock
pnpm-lock.yaml

# environment variables
.envrc
# Django dependencies
venv/
# Python cache
__pycache__/
*.py[cod]
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 
.vscode/
.idea/
*.swp
*.swo